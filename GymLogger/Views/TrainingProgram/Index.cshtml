@{
    ViewData["Title"] = "Training Programs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Training Programs</h2>
</div>

<div class="text-center py-5">
    <div class="fs-1 mb-3">📋</div>
    <h4 class="fw-bold mb-2">Coming Soon</h4>
    <p class="text-muted mb-4">
        Structured training programs are under development.<br />
        In the meantime, keep logging your workouts to track your progress.
    </p>
    <div class="d-flex gap-2 justify-content-center">
        <a asp-controller="Workout" asp-action="Create" class="btn btn-primary">Log a Workout</a>
        <a asp-controller="Exercise" asp-action="Index" class="btn btn-outline-secondary">Browse Exercises</a>
    </div>
</div>
