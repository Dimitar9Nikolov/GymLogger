@* Parameters: int CurrentPage, int TotalPages, object RouteValues (anonymous object with filter state) *@
@{
    int currentPage = (int)ViewData["CurrentPage"]!;
    int totalPages = (int)ViewData["TotalPages"]!;
    var routeValues = ViewData["RouteValues"] as Dictionary<string, string?>;
}

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mb-0">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data='@routeValues'
                   asp-route-page="@(currentPage - 1)">Previous</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-all-route-data='@routeValues'
                       asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data='@routeValues'
                   asp-route-page="@(currentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
