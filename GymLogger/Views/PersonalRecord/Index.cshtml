@model PersonalRecordListViewModel
@{
    ViewData["Title"] = "Personal Records";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Personal Records</h2>
    <a asp-controller="Workout" asp-action="Create" class="btn btn-primary">+ Log Workout</a>
</div>

<p class="text-muted mb-4">
    Your best performance per exercise across all logged workouts.
</p>

@if (!Model.StrengthRecords.Any() && !Model.CardioRecords.Any())
{
    <div class="text-center text-muted py-5">
        <div class="fs-1 mb-3">🏆</div>
        <h5>No records yet</h5>
        <p class="mb-3">Log a workout to start tracking your personal bests.</p>
        <a asp-controller="Workout" asp-action="Create" class="btn btn-primary">Log your first workout</a>
    </div>
}
else
{
    <!-- Strength PRs -->
    @if (Model.StrengthRecords.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-semibold">🏋️ Strength Records — Best Weight per Exercise</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Exercise</th>
                            <th>Muscle Group</th>
                            <th>Best Weight</th>
                            <th>Reps</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pr in Model.StrengthRecords)
                        {
                            <tr>
                                <td class="fw-medium">@pr.ExerciseName</td>
                                <td><span class="badge bg-secondary">@pr.MuscleGroup</span></td>
                                <td>
                                    @if (pr.WeightKg > 0)
                                    {
                                        <span class="fw-bold text-primary">@pr.WeightKg kg</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Bodyweight</span>
                                    }
                                </td>
                                <td>@(pr.Reps.HasValue ? pr.Reps.ToString() : "—")</td>
                                <td class="text-muted">@pr.Date.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Cardio PRs -->
    @if (Model.CardioRecords.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-semibold">🏃 Cardio Records — Best Speed per Exercise</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Exercise</th>
                            <th>Best Speed</th>
                            <th>Distance</th>
                            <th>Duration</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pr in Model.CardioRecords)
                        {
                            <tr>
                                <td class="fw-medium">@pr.ExerciseName</td>
                                <td>
                                    @if (pr.SpeedKmh.HasValue)
                                    {
                                        <span class="fw-bold text-success">@pr.SpeedKmh km/h</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@(pr.DistanceKm.HasValue ? $"{pr.DistanceKm} km" : "—")</td>
                                <td>@(pr.DurationMinutes.HasValue ? $"{pr.DurationMinutes} min" : "—")</td>
                                <td class="text-muted">@pr.Date.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
