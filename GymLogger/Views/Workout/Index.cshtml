@model WorkoutIndexViewModel
@{
    ViewData["Title"] = "My Workouts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">My Workouts</h2>
    <a asp-action="Create" class="btn btn-primary">+ Log Workout</a>
</div>

<!-- Filter bar -->
<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-sm-5 col-md-4">
        <input type="text" name="search" value="@Model.Search"
               class="form-control" placeholder="Search by title..." />
    </div>
    <div class="col-sm-3 col-md-2">
        <input type="date" name="from" value="@Model.From?.ToString("yyyy-MM-dd")"
               class="form-control" placeholder="From" />
    </div>
    <div class="col-sm-3 col-md-2">
        <input type="date" name="to" value="@Model.To?.ToString("yyyy-MM-dd")"
               class="form-control" placeholder="To" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
        <a asp-action="Index" class="btn btn-link text-muted">Clear</a>
    </div>
</form>

@{
    ViewData["CurrentPage"] = Model.CurrentPage;
    ViewData["TotalPages"] = Model.TotalPages;
    ViewData["RouteValues"] = new Dictionary<string, string?>
    {
        ["search"] = Model.Search,
        ["from"]   = Model.From?.ToString("yyyy-MM-dd"),
        ["to"]     = Model.To?.ToString("yyyy-MM-dd")
    };
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Workouts.Any())
{
    <div class="text-center text-muted py-5">
        <p class="mb-2">No workouts found.</p>
        <a asp-action="Create" class="btn btn-primary">Log your first workout</a>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Workout</th>
                        <th>Date</th>
                        <th>Duration</th>
                        <th>Exercises</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var workout in Model.Workouts)
                    {
                        <tr>
                            <td class="fw-medium">@workout.Title</td>
                            <td class="text-muted">@workout.Date.ToString("dd MMM yyyy")</td>
                            <td class="text-muted">@workout.DurationMinutes min</td>
                            <td class="text-muted">@workout.ExerciseCount</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Details" asp-route-id="@workout.Id"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                    <a asp-action="Edit" asp-route-id="@workout.Id"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@workout.Id"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
}
