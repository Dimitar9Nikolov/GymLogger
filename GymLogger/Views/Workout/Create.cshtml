@model WorkoutFormViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Log Workout";
    var cardioIds = Json.Serialize(Model.CardioExerciseIds);
}

<div class="mb-3">
    <a asp-action="Index" class="text-muted text-decoration-none">&larr; Back to Workouts</a>
</div>

<h2 class="mb-4">Log a Workout</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card mb-4">
        <div class="card-header fw-semibold">Workout Details</div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="e.g. Monday Push Day" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="Date" class="form-label"></label>
                    <input asp-for="Date" class="form-control" type="date" />
                    <span asp-validation-for="Date" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="DurationMinutes" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="DurationMinutes" class="form-control" type="number" min="1" max="1440" />
                        <span class="input-group-text">min</span>
                    </div>
                    <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                </div>
            </div>
            <div>
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any notes about this workout..."></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div class="mb-4" id="exerciseList"></div>

    <div class="d-flex gap-2 mb-4">
        <button type="button" id="addExercise" class="btn btn-outline-primary">+ Add Exercise</button>
    </div>

    <div id="emptyState" class="text-center text-muted py-3 mb-4">
        <p class="mb-0 small">No exercises added yet. Click <strong>+ Add Exercise</strong> to start.</p>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Workout</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<!-- Strength exercise template -->
<template id="exerciseTemplate">
    <div class="card mb-3 exercise-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <select name="Exercises[__ei__].ExerciseId" class="exercise-select form-select form-select-sm w-auto"
                    style="min-width:220px;">
                <option value="">Select exercise...</option>
                @if (Model.ExerciseOptions != null)
                {
                    @foreach (SelectListItem opt in Model.ExerciseOptions)
                    {
                        <option value="@opt.Value">@opt.Text</option>
                    }
                }
            </select>
            <button type="button" class="btn btn-sm btn-outline-danger removeExercise">Remove exercise</button>
        </div>
        <div class="card-body p-0">
            <!-- Strength headers -->
            <div class="set-headers-strength row g-0 px-3 pt-3 pb-1 text-muted small fw-semibold border-bottom">
                <div class="col-1">Set</div>
                <div class="col-3">Reps</div>
                <div class="col-3">Weight (kg)</div>
                <div class="col-5"></div>
            </div>
            <!-- Cardio headers -->
            <div class="set-headers-cardio row g-0 px-3 pt-3 pb-1 text-muted small fw-semibold border-bottom d-none">
                <div class="col-1">Set</div>
                <div class="col-3">Duration (min)</div>
                <div class="col-3">Distance (km)</div>
                <div class="col-5"></div>
            </div>
            <div class="set-list px-3 py-2"></div>
            <div class="px-3 pb-3">
                <button type="button" class="btn btn-sm btn-outline-secondary addSet">+ Add Set</button>
            </div>
        </div>
        <div class="card-footer">
            <label class="form-label small text-muted mb-1">Notes (optional)</label>
            <input type="text" name="Exercises[__ei__].Notes" class="form-control form-control-sm"
                   placeholder="e.g. paused reps, close grip..." />
        </div>
    </div>
</template>

<!-- Strength set row template -->
<template id="strengthSetTemplate">
    <div class="set-row row g-2 align-items-center mb-2">
        <div class="col-1 text-muted small set-number fw-semibold"></div>
        <div class="col-3">
            <input type="number" name="Exercises[__ei__].Sets[__si__].Reps"
                   class="form-control form-control-sm" min="1" max="200" value="10" />
        </div>
        <div class="col-3">
            <input type="number" name="Exercises[__ei__].Sets[__si__].WeightKg"
                   class="form-control form-control-sm" min="0" step="0.5" value="0" />
        </div>
        <div class="col-2">
            <button type="button" class="btn btn-sm btn-link text-danger removeSet p-0">Remove</button>
        </div>
    </div>
</template>

<!-- Cardio set row template -->
<template id="cardioSetTemplate">
    <div class="set-row row g-2 align-items-center mb-2">
        <div class="col-1 text-muted small set-number fw-semibold"></div>
        <div class="col-3">
            <input type="number" name="Exercises[__ei__].Sets[__si__].DurationMinutes"
                   class="form-control form-control-sm" min="1" max="1440" value="30" />
        </div>
        <div class="col-3">
            <input type="number" name="Exercises[__ei__].Sets[__si__].DistanceKm"
                   class="form-control form-control-sm" min="0" step="0.1" value="0" />
        </div>
        <div class="col-2">
            <button type="button" class="btn btn-sm btn-link text-danger removeSet p-0">Remove</button>
        </div>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const cardioIds            = new Set(@Html.Raw(cardioIds));
        const exerciseList         = document.getElementById('exerciseList');
        const emptyState           = document.getElementById('emptyState');
        const exerciseTemplate     = document.getElementById('exerciseTemplate');
        const strengthSetTemplate  = document.getElementById('strengthSetTemplate');
        const cardioSetTemplate    = document.getElementById('cardioSetTemplate');
        let exerciseIndex          = 0;

        function isCardioCard(card) {
            return card.dataset.cardio === 'true';
        }

        function applyCardioMode(card, isCardio) {
            card.dataset.cardio = isCardio;
            card.querySelector('.set-headers-strength').classList.toggle('d-none', isCardio);
            card.querySelector('.set-headers-cardio').classList.toggle('d-none', !isCardio);
            // Clear existing sets and add a fresh one in the right mode
            card.querySelector('.set-list').innerHTML = '';
            addSet(card);
        }

        function updateEmptyState() {
            emptyState.classList.toggle('d-none', exerciseList.children.length > 0);
        }

        function reindexAll() {
            exerciseList.querySelectorAll('.exercise-card').forEach((card, ei) => {
                card.querySelectorAll('[name]').forEach(el => {
                    el.name = el.name.replace(/Exercises\[\d+\]/, `Exercises[${ei}]`);
                });
                card.querySelectorAll('.set-row').forEach((row, si) => {
                    row.querySelectorAll('[name]').forEach(el => {
                        el.name = el.name.replace(/Sets\[\d+\]/, `Sets[${si}]`);
                    });
                    row.querySelector('.set-number').textContent = si + 1;
                });
            });
            exerciseIndex = exerciseList.querySelectorAll('.exercise-card').length;
        }

        function addSet(card) {
            const ei       = [...exerciseList.querySelectorAll('.exercise-card')].indexOf(card);
            const setList  = card.querySelector('.set-list');
            const si       = setList.querySelectorAll('.set-row').length;
            const tmpl     = isCardioCard(card) ? cardioSetTemplate : strengthSetTemplate;
            const html     = tmpl.innerHTML.replaceAll('__ei__', ei).replaceAll('__si__', si);
            setList.insertAdjacentHTML('beforeend', html);
            setList.lastElementChild.querySelector('.set-number').textContent = si + 1;
        }

        document.getElementById('addExercise').addEventListener('click', () => {
            const html = exerciseTemplate.innerHTML.replaceAll('__ei__', exerciseIndex);
            exerciseList.insertAdjacentHTML('beforeend', html);
            const card = exerciseList.lastElementChild;
            card.dataset.cardio = 'false';
            addSet(card);
            exerciseIndex++;
            updateEmptyState();

            // Wire up the select change handler for this new card
            card.querySelector('.exercise-select').addEventListener('change', function () {
                const selectedId = parseInt(this.value);
                const isCardio = cardioIds.has(selectedId);
                applyCardioMode(card, isCardio);
                reindexAll();
            });
        });

        exerciseList.addEventListener('click', e => {
            if (e.target.classList.contains('removeExercise')) {
                e.target.closest('.exercise-card').remove();
                reindexAll();
                updateEmptyState();
            }
            if (e.target.classList.contains('addSet')) {
                addSet(e.target.closest('.exercise-card'));
            }
            if (e.target.classList.contains('removeSet')) {
                e.target.closest('.set-row').remove();
                reindexAll();
            }
        });

        updateEmptyState();
    </script>
}
