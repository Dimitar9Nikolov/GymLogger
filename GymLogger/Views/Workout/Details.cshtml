@model WorkoutDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-action="Index" class="text-muted text-decoration-none">&larr; Back to Workouts</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h2 class="mb-1">@Model.Title</h2>
                <div class="d-flex gap-3 text-muted small">
                    <span>📅 @Model.Date.ToString("dd MMM yyyy")</span>
                    <span>⏱ @Model.DurationMinutes min</span>
                    <span>🏋️ @Model.Exercises.Count exercise@(Model.Exercises.Count == 1 ? "" : "s")</span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <hr />
            <p class="mb-0 text-muted" style="white-space: pre-line;">@Model.Notes</p>
        }
    </div>
</div>

@if (!Model.Exercises.Any())
{
    <div class="text-center text-muted py-4">
        <p class="mb-0">No exercises logged for this workout.</p>
    </div>
}
else
{
    @foreach (var exercise in Model.Exercises)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">@exercise.Order. @exercise.ExerciseName</span>
                @if (exercise.IsCardio)
                {
                    <span class="badge bg-success">Cardio</span>
                }
                else
                {
                    <span class="badge bg-primary">Strength</span>
                }
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">Set</th>
                            @if (exercise.IsCardio)
                            {
                                <th>Duration</th>
                                <th>Distance</th>
                            }
                            else
                            {
                                <th>Reps</th>
                                <th>Weight</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!exercise.Sets.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-muted small">No sets logged</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var set in exercise.Sets)
                            {
                                <tr>
                                    <td class="text-muted">@set.SetNumber</td>
                                    @if (exercise.IsCardio)
                                    {
                                        <td>@(set.DurationMinutes.HasValue ? $"{set.DurationMinutes} min" : "—")</td>
                                        <td>@(set.DistanceKm.HasValue ? $"{set.DistanceKm} km" : "—")</td>
                                    }
                                    else
                                    {
                                        <td>@(set.Reps.HasValue ? set.Reps.ToString() : "—")</td>
                                        <td>@(set.WeightKg.HasValue ? $"{set.WeightKg} kg" : "—")</td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            @if (!string.IsNullOrEmpty(exercise.Notes))
            {
                <div class="card-footer text-muted small">📝 @exercise.Notes</div>
            }
        </div>
    }
}
