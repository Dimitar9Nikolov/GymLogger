@model WorkoutDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-action="Index" class="text-muted text-decoration-none">&larr; Back to Workouts</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Workout header -->
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h2 class="mb-1">@Model.Title</h2>
                <div class="d-flex gap-3 text-muted small">
                    <span>📅 @Model.Date.ToString("dd MMM yyyy")</span>
                    <span>⏱ @Model.DurationMinutes min</span>
                    <span>🏋️ @Model.Exercises.Count exercise@(Model.Exercises.Count == 1 ? "" : "s")</span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <hr />
            <p class="mb-0 text-muted" style="white-space: pre-line;">@Model.Notes</p>
        }
    </div>
</div>

<!-- Exercise table -->
@if (!Model.Exercises.Any())
{
    <div class="text-center text-muted py-4">
        <p class="mb-0">No exercises logged for this workout.</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-header fw-semibold">Exercises</div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px">#</th>
                        <th>Exercise</th>
                        <th>Set</th>
                        <th>Reps</th>
                        <th>Weight</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exercise in Model.Exercises)
                    {
                        @if (!exercise.Sets.Any())
                        {
                            <tr>
                                <td class="text-muted">@exercise.Order</td>
                                <td class="fw-medium">@exercise.ExerciseName</td>
                                <td colspan="3" class="text-muted small">No sets logged</td>
                                <td class="text-muted small">@exercise.Notes</td>
                            </tr>
                        }
                        else
                        {
                            @for (int s = 0; s < exercise.Sets.Count; s++)
                            {
                                var set = exercise.Sets[s];
                                <tr>
                                    @if (s == 0)
                                    {
                                        <!-- Only show the exercise number and name on the first set row -->
                                        <td class="text-muted align-top" rowspan="@exercise.Sets.Count">@exercise.Order</td>
                                        <td class="fw-medium align-top" rowspan="@exercise.Sets.Count">
                                            @exercise.ExerciseName
                                        </td>
                                    }
                                    <td class="text-muted">@set.SetNumber</td>
                                    <td>@set.Reps</td>
                                    <td>@set.WeightKg kg</td>
                                    @if (s == 0)
                                    {
                                        <td class="text-muted small align-top" rowspan="@exercise.Sets.Count">@exercise.Notes</td>
                                    }
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
